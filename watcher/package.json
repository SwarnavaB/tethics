{
  "name": "tethics-watcher",
  "version": "0.1.0",
  "description": "Community watcher CLI for tethics. Detects unauthorized tokens and reports them onchain.",
  "main": "dist/index.js",
  "bin": {
    "tethics-watcher": "dist/index.js"
  },
  "scripts": {
    "build": "node ../node_modules/typescript/bin/tsc",
    "dev": "ts-node src/index.ts",
    "start": "node dist/index.js",
    "watch": "node ../node_modules/typescript/bin/tsc --watch"
  },
  "dependencies": {
    "viem": "^2.0.0",
    "commander": "^12.0.0",
    "chalk": "^5.3.0",
    "dotenv": "^16.4.0"
  },
  "devDependencies": {
    "typescript": "^5.4.0",
    "@types/node": "^20.0.0",
    "ts-node": "^10.9.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "license": "MIT"
}
