# tethics Watcher - Environment Variables

# Registry contract address (update after deployment)
REGISTRY_ADDRESS=0x...

# Your reporter wallet private key (for auto-report mode)
# This wallet pays gas for report transactions.
# The reporter earns onchain reputation for accurate reports.
REPORTER_PRIVATE_KEY=0x...

# Optional: custom RPC URLs (defaults to public endpoints)
BASE_RPC_URL=https://mainnet.base.org
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org
